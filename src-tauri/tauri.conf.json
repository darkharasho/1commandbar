{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "1commandbar",
  "version": "0.1.16",
  "identifier": "dev.1commandbar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "bar",
        "title": "1commandbar",
        "width": 440,
        "height": 200,
        "minWidth": 440,
        "minHeight": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "category": "Utility",
    "shortDescription": "1Password command bar for Linux",
    "longDescription": "A global-hotkey command bar for 1Password on Linux, backed by the op CLI."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3RjBGMDBBNkIzQUI5NEUKUldST3VUcHJDdkR3cDQ4ZGpJalB2WDh1dzVUMmsrOUtVSklabERtRFBqeFRLWm5wYVlzY0xZaTAK",
      "endpoints": [
        "https://github.com/darkharasho/1commandbar/releases/latest/download/latest.json"
      ]
    }
  }
}
